# ========================================
# BACKEND ENVIRONMENT VARIABLES
# ========================================

# Application Environment (development, production)
NODE_ENV=development

# Server Port Number
PORT=5001

# MongoDB Connection String (Replace with your actual MongoDB URI)
MONGODB_URI=mongodb://127.0.0.1:27017/edwardian-erp-placeholder

# JWT Authentication
# Secret key used to sign JWT tokens (Must be a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
# Expiration time for JWT tokens
JWT_EXPIRES_IN=7d

# CORS and Allowed Origins (Frontend URLs)
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# The primary frontend URL
CLIENT_URL=http://localhost:5173

# Cookie Security Settings
# SameSite attribute (Lax, Strict, or None) - use None for cross-origin with Secure=true
COOKIE_SAME_SITE=Lax
# Secure attribute (true/false) - true requires HTTPS
COOKIE_SECURE=false
# Domain attribute for cookies (Optional, leave blank for local/default domain)
COOKIE_DOMAIN=

# ========================================
# FRONTEND ENVIRONMENT VARIABLES
# ========================================

# Base URL for API requests (usually the backend root URL)
VITE_API_BASE_URL=http://localhost:5001
# Explicit API URL (with /api suffix if used in some legacy calls)
VITE_API_URL=http://localhost:5001/api
