# MongoDB Connection String
# For local MongoDB
MONGODB_URI=mongodb://localhost:27017/edwardianDB

# For MongoDB Atlas (uncomment and use your connection string)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/academyDB?retryWrites=true&w=majority

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Legacy single client URL (optional)
CLIENT_URL=http://localhost:8080

# CORS allowlist (comma-separated)
# Example: https://erp.yourdomain.com,https://yourpublicdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Cookie settings (optional overrides)
# COOKIE_SAME_SITE=strict
# COOKIE_SECURE=true
# COOKIE_DOMAIN=.yourdomain.com
# STUDENT_COOKIE_SAME_SITE=lax
# STUDENT_COOKIE_SECURE=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters
JWT_EXPIRES_IN=7d
